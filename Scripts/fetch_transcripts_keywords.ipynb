def sanitize(s: str, max_len: int = 80) -> str:
    s = re.sub(r"[^\w\- ]+", "", s, flags=re.UNICODE).strip()
    s = re.sub(r"\s+", "_", s)
    return s[:max_len] if len(s) > max_len else s


def parse_channel_url(url: str) -> Tuple[Optional[str], Optional[str]]:
    """Returns (UC_channel_id, handle) if detected in URL."""
    if not isinstance(url, str):
        return None, None
    url = url.strip()
    m = re.search(r"(UC[a-zA-Z0-9_-]{20,})", url)
    uc = m.group(1) if m else None
    m = re.search(r"/@([a-zA-Z0-9_.-]+)", url)
    handle = m.group(1) if m else None
    return uc, handle


def chunked(seq: List[str], n: int) -> Iterable[List[str]]:
    for i in range(0, len(seq), n):
        yield seq[i : i + n]


def resolve_channel_uc(youtube, channel_url: str, channel_name: str) -> Optional[str]:
    """
    Best-effort channel identifier resolution.
    Priority:
      1) UC... in URL
      2) @handle via channels.list(forHandle=...)
      3) search by channel_name (ambiguous fallback)
    """
    uc, handle = parse_channel_url(channel_url)
    if uc:
        return uc

    if handle:
        try:
            resp = youtube.channels().list(part="id", forHandle=handle).execute()
            items = resp.get("items", [])
            if items:
                return items[0]["id"]
        except Exception:
            pass

    try:
        resp = youtube.search().list(
            part="snippet",
            q=channel_name,
            type="channel",
            maxResults=1,
        ).execute()
        items = resp.get("items", [])
        if items:
            return items[0]["snippet"]["channelId"]
    except Exception:
        pass

    return None


def get_uploads_playlist_id(youtube, channel_uc: str) -> Optional[str]:
    resp = youtube.channels().list(part="contentDetails", id=channel_uc).execute()
    items = resp.get("items", [])
    if not items:
        return None
    return items[0]["contentDetails"]["relatedPlaylists"]["uploads"]


def list_video_ids_from_uploads(youtube, uploads_playlist_id: str, max_videos: int) -> List[str]:
    video_ids: List[str] = []
    page_token = None

    while len(video_ids) < max_videos:
        resp = youtube.playlistItems().list(
            part="contentDetails",
            playlistId=uploads_playlist_id,
            maxResults=min(50, max_videos - len(video_ids)),
            pageToken=page_token,
        ).execute()

        for item in resp.get("items", []):
            video_ids.append(item["contentDetails"]["videoId"])

        page_token = resp.get("nextPageToken")
        if not page_token:
            break

    return video_ids


def get_video_metadata(youtube, video_ids: List[str]) -> List[Dict]:
    rows: List[Dict] = []
    for batch in chunked(video_ids, 50):
        resp = youtube.videos().list(part="snippet,contentDetails", id=",".join(batch)).execute()
        for v in resp.get("items", []):
            snippet = v["snippet"]
            cd = v["contentDetails"]
            title = snippet.get("title", "")
            description = snippet.get("description", "")
            published_at = snippet.get("publishedAt", "")
            year = int(published_at[:4]) if published_at else None
            dur_iso = cd.get("duration", "PT0S")
            dur_seconds = int(isodate.parse_duration(dur_iso).total_seconds())
            rows.append(
                {
                    "video_id": v["id"],
                    "title": title,
                    "description": description,
                    "published_at": published_at,
                    "year": year,
                    "duration_iso": dur_iso,
                    "duration_seconds": dur_seconds,
                }
            )
    return rows


def keyword_match(text: str, keywords: List[str]) -> bool:
    if not keywords:
        return True
    t = (text or "").lower()
    return any(k in t for k in keywords)


def fetch_transcript(video_id: str, prefer_langs: List[str]) -> Optional[str]:
    try:
        for lang in prefer_langs:
            try:
                transcript = YouTubeTranscriptApi.get_transcript(video_id, languages=[lang])
                return " ".join([t["text"] for t in transcript])
            except Exception:
                pass

        transcript = YouTubeTranscriptApi.get_transcript(video_id)
        return " ".join([t["text"] for t in transcript])

    except (TranscriptsDisabled, NoTranscriptFound, CouldNotRetrieveTranscript):
        return None
    except Exception:
        return None


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--api_key", required=True, help="YouTube Data API v3 key")
    ap.add_argument("--registry_xlsx", required=True, help="Path to channel registry xlsx")
    ap.add_argument("--sheet", default=None, help="Sheet name (optional). If omitted, uses first sheet.")
    ap.add_argument("--out_dir", default="out_transcripts", help="Output folder")
    ap.add_argument("--min_minutes", type=float, default=5.0, help="Minimum video length (minutes)")
    ap.add_argument("--per_channel", type=int, default=10, help="How many qualifying videos per channel")
    ap.add_argument("--scan_recent", type=int, default=80, help="How many newest uploads to scan per channel")
    ap.add_argument("--prefer_langs", default="en,en-GB,en-US", help="Comma-separated transcript language preferences")
    ap.add_argument("--included_only", action="store_true", help="Only process Included (Yes/No) == Yes, if column exists")
    ap.add_argument(
        "--keywords",
        default="ransomware,extortion,double extortion,locker,encrypt,encryption,incident response,IR,conti,lockbit,alphv,blackcat,ryuk,cl0p,clop,akira",
        help="Comma-separated keywords to match in title/description (case-insensitive substring match)",
    )
    ap.add_argument("--match_description", action="store_true", help="Also match keywords against description (default: title only)")
    args = ap.parse_args()

    min_seconds = int(args.min_minutes * 60)
    prefer_langs = [s.strip() for s in args.prefer_langs.split(",") if s.strip()]
    keywords = [k.strip().lower() for k in args.keywords.split(",") if k.strip()]

    youtube = build("youtube", "v3", developerKey=args.api_key)

    df = pd.read_excel(args.registry_xlsx, sheet_name=args.sheet)

    required_cols = {"Channel_ID", "Channel_Name", "Channel_URL"}
    missing = required_cols - set(df.columns)
    if missing:
        raise SystemExit(f"Registry is missing required columns: {sorted(missing)}")

    if args.included_only and "Included (Yes/No)" in df.columns:
        df = df[df["Included (Yes/No)"].astype(str).str.strip().str.lower().eq("yes")].copy()

    out_dir = Path(args.out_dir)
    out_dir.mkdir(parents=True, exist_ok=True)

    manifest_path = out_dir / "manifest.csv"
    manifest_fields = [
        "Video_ID",
        "Channel_ID",
        "Channel_Name",
        "Channel_UC",
        "YouTube_Video_ID",
        "Video_Title",
        "Year",
        "PublishedAt",
        "DurationSeconds",
        "DurationISO",
        "Matched_Keywords",
        "Transcript_Available",
        "Transcript_Path",
        "Meta_Path",
    ]

    global_counter = 1
    manifest_rows = []

    for _, row in df.iterrows():
        channel_id = str(row["Channel_ID"]).strip()
        channel_name = str(row["Channel_Name"]).strip()
        channel_url = str(row["Channel_URL"]).strip()

        channel_uc = resolve_channel_uc(youtube, channel_url, channel_name)
        if not channel_uc:
            print(f"[WARN] Could not resolve channel UC id for {channel_id} | {channel_name}")
            continue

        uploads = get_uploads_playlist_id(youtube, channel_uc)
        if not uploads:
            print(f"[WARN] Could not get uploads playlist for channel {channel_id} ({channel_uc})")
            continue

        scan_n = max(args.scan_recent, args.per_channel)
        video_ids = list_video_ids_from_uploads(youtube, uploads, max_videos=scan_n)
        if not video_ids:
            print(f"[WARN] No videos found for channel {channel_id} ({channel_uc})")
            continue

        meta = get_video_metadata(youtube, video_ids)

        # Filter duration
        meta = [m for m in meta if m["duration_seconds"] >= min_seconds]

        # Keyword filtering
        selected = []
        for m in meta:
            title = m.get("title", "")
            desc = m.get("description", "")
            text = title if not args.match_description else (title + "\n" + desc)
            if keyword_match(text, keywords):
                # record matched keywords for transparency
                t = (text or "").lower()
                matched = [k for k in keywords if k in t]
                m["matched_keywords"] = ";".join(sorted(set(matched))) if matched else ""
                selected.append(m)

        selected = selected[: args.per_channel]  # uploads order is newest-first

        channel_folder = out_dir / f"{channel_id}_{sanitize(channel_name)}"
        channel_folder.mkdir(parents=True, exist_ok=True)

        kept = 0
        for m in selected:
            yt_vid = m["video_id"]
            title = m["title"]
            year = m["year"]
            published_at = m["published_at"]
            dur_s = m["duration_seconds"]
            dur_iso = m["duration_iso"]
            matched_kw = m.get("matched_keywords", "")

            transcript_text = fetch_transcript(yt_vid, prefer_langs)
            transcript_available = transcript_text is not None

            video_id = f"V{global_counter:04d}"
            global_counter += 1

            txt_path = channel_folder / f"{video_id}.txt"
            meta_path = channel_folder / f"{video_id}.meta.json"

            if transcript_text is None:
                transcript_text = "[NO TRANSCRIPT AVAILABLE]\n"
            txt_path.write_text(transcript_text, encoding="utf-8")

            meta_payload = {
                "Video_ID": video_id,
                "Channel_ID": channel_id,
                "Channel_Name": channel_name,
                "Channel_UC": channel_uc,
                "YouTube_Video_ID": yt_vid,
                "Video_Title": title,
                "Year": year,
                "PublishedAt": published_at,
                "DurationSeconds": dur_s,
                "DurationISO": dur_iso,
                "Matched_Keywords": matched_kw,
                "Transcript_Available": transcript_available,
            }
            meta_path.write_text(json.dumps(meta_payload, indent=2), encoding="utf-8")

            manifest_rows.append(
                {
                    "Video_ID": video_id,
                    "Channel_ID": channel_id,
                    "Channel_Name": channel_name,
                    "Channel_UC": channel_uc,
                    "YouTube_Video_ID": yt_vid,
                    "Video_Title": title,
                    "Year": year,
                    "PublishedAt": published_at,
                    "DurationSeconds": dur_s,
                    "DurationISO": dur_iso,
                    "Matched_Keywords": matched_kw,
                    "Transcript_Available": transcript_available,
                    "Transcript_Path": str(txt_path),
                    "Meta_Path": str(meta_path),
                }
            )

            kept += 1

        print(f"[OK] {channel_id} | selected {kept} video(s) | output -> {channel_folder}")

    with manifest_path.open("w", newline="", encoding="utf-8") as f:
        w = csv.DictWriter(f, fieldnames=manifest_fields)
        w.writeheader()
        for r in manifest_rows:
            w.writerow(r)

    print(f"\nDone. Manifest: {manifest_path}")
